# Copier ce fichier en .env et remplir les valeurs

# Connexion MongoDB (local ou Atlas)
# Local :  mongodb://localhost:27017/padel-tournoi
# Atlas :  mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/padel-tournoi
MONGODB_URI=mongodb://localhost:27017/padel-tournoi

# Clé secrète pour les tokens JWT — mets une chaîne longue et aléatoire
JWT_SECRET=change_me_to_something_very_long_and_random

# URL publique du site (pour le QR code)
PUBLIC_URL=http://localhost:5173

# URL du client React (pour le CORS)
CLIENT_URL=http://localhost:5173

# Port du serveur (optionnel, défaut 3001)
PORT=3001
